@model Examen_Parcial_Plataforma_de_Cr_ditos.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<h2>Detalle de Solicitud #@Model.Id</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Monto Solicitado</dt>
            <dd class="col-sm-9">@Model.MontoSolicitado.ToString("C")</dd>

            <dt class="col-sm-3">Fecha Solicitud</dt>
            <dd class="col-sm-9">@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                @if (Model.Estado == "Pendiente")
                {
                    <span class="badge bg-warning">@Model.Estado</span>
                }
                else if (Model.Estado == "Aprobado")
                {
                    <span class="badge bg-success">@Model.Estado</span>
                }
                else
                {
                    <span class="badge bg-danger">@Model.Estado</span>
                }
            </dd>

            @if (!string.IsNullOrEmpty(Model.MotivoRechazo))
            {
                <dt class="col-sm-3">Motivo Rechazo</dt>
                <dd class="col-sm-9">@Model.MotivoRechazo</dd>
            }
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="MisSolicitudes" class="btn btn-secondary">Volver a Mis Solicitudes</a>
    
    @if (Model.Estado == "Pendiente")
    {
        <form asp-action="Cancelar" asp-route-id="@Model.Id" method="post" class="d-inline" 
              onsubmit="return confirm('¿Estás seguro de cancelar esta solicitud?');">
            <button type="submit" class="btn btn-danger ms-2">Cancelar Solicitud</button>
        </form>
    }
</div>