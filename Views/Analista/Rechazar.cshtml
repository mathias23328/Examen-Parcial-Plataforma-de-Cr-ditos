@{
    ViewData["Title"] = "Rechazar Solicitud";
    var solicitudId = ViewBag.SolicitudId;
    var monto = ViewBag.Monto;
}

<h2>Rechazar Solicitud #@solicitudId</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Monto solicitado:</strong> @monto.ToString("C")</p>
        
        <form method="post" asp-action="Rechazar" asp-route-id="@solicitudId">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <div class="form-group mb-3">
                <label class="form-label">Motivo de Rechazo *</label>
                <textarea name="motivo" class="form-control" rows="4" required 
                          placeholder="Explique el motivo del rechazo..."></textarea>
                <small class="text-muted">El motivo es obligatorio y será visible para el cliente.</small>
            </div>
            
            <button type="submit" class="btn btn-danger">Confirmar Rechazo</button>
            <a asp-action="Panel" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>